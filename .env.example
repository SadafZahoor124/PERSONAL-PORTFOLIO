# Copy this file to .env.local and fill in your real values.
# These are used by the /api/contact route (src/app/api/contact/route.ts)
# to send an email via SMTP whenever someone submits the contact form.

# SMTP host, e.g. smtp.gmail.com
SMTP_HOST=smtp.gmail.com
# SMTP port, 465 for SSL or 587 for TLS
SMTP_PORT=465
# Whether to use a secure (SSL) connection - true for port 465, false for 587
SMTP_SECURE=true
# The SMTP account username (often your full email address)
SMTP_USER=your-email@gmail.com
# The SMTP account password or app-specific password
SMTP_PASS=your-app-password
# The address that should receive portfolio contact messages
CONTACT_RECEIVER_EMAIL=your-email@gmail.com
